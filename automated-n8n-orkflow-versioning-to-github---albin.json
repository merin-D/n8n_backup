        "id": "5c708621-bcbf-43b7-b0ca-03b5c26b235c",
        "name": "Code in JavaScript1"
      },
      {
        "parameters": {
          "jsCode": "// Get GitHub file names - these are the raw filenames in the repo\nconst githubFiles = $('List files from repo').all().map(i => i.json.name).filter(Boolean);\n\n// Get n8n workflow names - build the same filename format used when uploading\nconst n8nWorkflows = $('Retrieve workflows').all().map(i => {\n  const name = i.json.name.replace(/\\s+/g, '-').toLowerCase();\n  const tag = (i.json.tags && i.json.tags[0]) ? i.json.tags[0].name : '';\n  return tag ? `${name}-${tag}.json` : `${name}.json`;\n});\n\n// Safety abort\nif (n8nWorkflows.length === 0) {\n  throw new Error('Safety abort: n8n returned 0 workflows. Refusing to delete.');\n}\n\nif (githubFiles.length === 0) {\n  return [{ json: { skipped: true, reason: 'No GitHub files found' } }];\n}\n\nconst filesToDelete = githubFiles.filter(f => !n8nWorkflows.includes(f));\n\nif (filesToDelete.length === 0) {\n  return [{ json: { skipped: true, reason: 'Nothing to delete' } }];\n}\n\nreturn filesToDelete.map(f => ({ json: { path: f, skipped: false } }));"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
